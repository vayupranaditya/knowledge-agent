{
  "name": "knowledge-bot",
  "version": "1.0.0",
  "description": "AI-powered knowledge base bot - removes knowledge silos with semantic search",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "chat": "tsx src/index.ts",
    "inspect:db": "tsx src/index.ts --inspect-db",
    "inspect:people": "tsx src/index.ts --inspect-people",
    "inspect:unverified": "tsx src/index.ts --inspect-unverified",
    "inspect:prompt": "tsx src/index.ts --inspect-prompt",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "server": "tsx src/api/start-server.ts",
    "server:dev": "tsx watch src/api/start-server.ts"
  },
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "better-sqlite3": "^11.7.0",
    "chalk": "^5.3.0",
    "cors": "^2.8.6",
    "dotenv": "^16.4.7",
    "express": "^5.2.1",
    "ink": "^5.1.0",
    "ink-text-input": "^6.0.0",
    "openai": "^4.77.0",
    "react": "^18.3.1",
    "uuid": "^11.0.5"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.0",
    "@types/uuid": "^10.0.0",
    "@vitest/coverage-v8": "^2.1.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
