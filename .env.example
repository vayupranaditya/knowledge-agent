# LLM Provider: "gemini" | "openai" | "ollama"
LLM_PROVIDER=ollama

# API Keys (only needed for cloud providers, not for ollama)
GEMINI_API_KEY=your-gemini-api-key-here
OPENAI_API_KEY=your-openai-api-key-here

# Model name (optional, defaults per provider)
# gemini: gemini-2.0-flash | openai: gpt-4o-mini | ollama: llama3
LLM_MODEL=

# Ollama base URL (optional, defaults to http://localhost:11434)
OLLAMA_BASE_URL=http://localhost:11434

# Database path (optional, defaults to ./data/knowledge.db)
DB_PATH=
